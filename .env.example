# Tavily Search Configuration
TAVILY_API_KEY="your_tavily_api_key_here"

# Groq Configuration
GROQ_API_KEY="your_groq_api_key_here"

# Qdrant Configuration
QDRANT_URL="http://localhost:6333"
QDRANT_API_KEY="your_qdrant_api_key_here"
QDRANT_CODE_COLLECTION="code_documents"
QDRANT_DOCS_COLLECTION="documents"

# MongoDB Configuration
MONGODB_URL="mongodb://localhost:27017"
MONGODB_DB_NAME="adaptive_rag"

# Pinecone Configuration
PINECONE_API_KEY="your_pinecone_api_key_here"
PINECONE_INDEX_NAME="my-rag-index"

# Rust Auth Service
# IMPORTANT: Change this to a long random secret before deploying to production!
# Generate one with: openssl rand -hex 32
JWT_SECRET="your_jwt_secret_here"
